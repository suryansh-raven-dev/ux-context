{
  "name": "near_miss_investigation_report",
  "description": "Configuration for rendering near-miss investigation reports",
  "sections": {
    "investigation_metadata": {
      "title": "Investigation Information",
      "icon": "DescriptionIcon",
      "fields": {
        "investigation_id": {
          "type": "string",
          "label": "Investigation ID"
        },
        "report_id": {
          "type": "string",
          "label": "Report ID"
        },
        "date": {
          "type": "string",
          "label": "Date"
        },
        "time": {
          "type": "string",
          "label": "Time"
        }
      }
    },
    "incident_classification": {
      "title": "Incident Classification",
      "icon": "VerifiedIcon",
      "type": "checkbox_group",
      "fields": {
        "workplace_safety_near_miss": {
          "type": "boolean",
          "label": "Workplace Safety Near Miss"
        },
        "process_safety_near_miss": {
          "type": "boolean",
          "label": "Process Safety Near Miss"
        }
      }
    },
    "direct_causes": {
      "title": "Direct Causes",
      "icon": "ErrorIcon",
      "subsections": {
        "unsafe_conditions": {
          "title": "Unsafe Conditions",
          "groups": {
            "equipment_related": {
              "title": "Equipment Related",
              "options": {
                "inadequate_guards": "Inadequate/Defective guards",
                "inadequate_warning": "Inadequate/Defective warning systems",
                "inadequate_ppe": "Inadequate/Defective PPE",
                "energized_electrical": "Energized electrical systems",
                "mechanical_hazards": "Mechanical hazards"
              }
            },
            "workplace_related": {
              "title": "Workplace Related",
              "options": {
                "poor_housekeeping": "Clutter or debris or poor housekeeping",
                "slippery_surfaces": "Slippery floors or walkways",
                "congested_space": "Congestion or restricted layout/workplace",
                "poor_accessibility": "Locations out of reach or sight",
                "unprotected_height": "Unprotected height"
              }
            },
            "environmental_related": {
              "title": "Environmental Related",
              "options": {
                "noise": "Noise",
                "static_electricity": "Static electricity",
                "radiation": "Radiation",
                "temperature_extremes": "Temperature extremes",
                "hazardous_materials": "Presence Hazardous chemicals/biological substances",
                "poor_illumination": "Inadequate or excessive illumination",
                "poor_ventilation": "Inadequate ventilation",
                "vibration": "Vibration"
              }
            }
          }
        },
        "unsafe_acts": {
          "title": "Unsafe Acts",
          "groups": {
            "procedural": {
              "title": "Procedural",
              "options": {
                "unauthorized_operation": "Operation of equipment without authority",
                "improper_speed": "Work or motion at improper speed",
                "equipment_misuse": "Operation of equipment at improper speed",
                "equipment_servicing": "Servicing of equipment in operation",
                "procedure_violation": "Work sequence/method statement not followed",
                "energized_servicing": "Servicing of energized equipment"
              }
            },
            "behavioral": {
              "title": "Behavioral",
              "options": {
                "improper_position": "Improper position or posture for the task",
                "improper_placement": "Improper placement of tools, equipment or materials",
                "poor_judgment": "Improper decision making or lack of judgement",
                "inattention": "Inattention to footing and surroundings",
                "horseplay": "Horseplay",
                "substance_abuse": "Drugs or alcohol intoxication"
              }
            },
            "organizational": {
              "title": "Organizational",
              "options": {
                "ppe_not_used": "Personal protective equipment not used",
                "improper_ppe": "Improper use of proper PPEs",
                "unsecured_equipment": "Equipment of materials not secured",
                "disabled_safety": "Disabled guards, warning systems or safety devices",
                "removed_safety": "Removal of guards, warning systems or safety devices",
                "violence": "Acts of violence/Sabotage"
              }
            }
          }
        }
      }
    },
    "root_cause_analysis": {
      "title": "Root Cause Analysis",
      "icon": "AccountTreeIcon",
      "fields": {
        "system_factors": {
          "type": "multiselect",
          "label": "System Factors",
          "options": {
            "hazard_identification": "Hazard Identification & risk assessment",
            "procedures": "Procedures & Practices",
            "work_permit": "Work Permit System",
            "training": "Personnel Training",
            "mechanical_integrity": "Mechanical Integrity",
            "quality_assurance": "Quality assurance of material",
            "safeguards": "Safeguards, Controls & Layers of Protection",
            "maintenance": "Preventive Maintenance",
            "moc": "Management of Change",
            "contractor": "Contractor Management",
            "design": "Design",
            "facility": "Facility Siting",
            "psrv": "Pre-startup Safety Review",
            "emergency": "Emergency Preparedness and Response",
            "resources": "Inadequate resources",
            "planning": "Poor work planning"
          }
        },
        "physical_factors": {
          "type": "multiselect",
          "label": "Physical Factors",
          "options": {
            "plant_design": "Poor design of plant and equipment",
            "maintenance": "Poorly maintained equipment",
            "workplace": "Workplace design/preparation",
            "equipment": "Work equipment",
            "tools": "Tools",
            "material": "Substandard material"
          }
        },
        "human_factors": {
          "type": "multiselect",
          "label": "Human Factors",
          "options": {
            "awareness": "Lack of awareness",
            "competence": "Low skill and competence levels",
            "medical": "Individual medical problems",
            "supervision": "Inadequate supervision",
            "fatigue": "Fatigued Staffs",
            "physical": "Physical capability",
            "environmental": "Diminished performance due environment"
          }
        }
      }
    },
    "barrier_analysis": {
      "title": "Barrier Analysis",
      "icon": "SecurityIcon",
      "fields": {
        "failed": {
          "type": "array",
          "label": "Failed Barriers",
          "icon": "ErrorIcon",
          "color": "error"
        },
        "successful": {
          "type": "array",
          "label": "Successful Barriers",
          "icon": "CheckCircleIcon",
          "color": "success"
        },
        "missing": {
          "type": "array",
          "label": "Missing Barriers",
          "icon": "WarningIcon",
          "color": "warning"
        }
      }
    },
    "conclusions": {
      "title": "Conclusions",
      "icon": "SummarizeIcon",
      "fields": {
        "incident_cause": {
          "type": "text",
          "label": "Incident Cause",
          "multiline": true
        },
        "prevention_possibility": {
          "type": "text",
          "label": "Prevention Possibility",
          "multiline": true
        }
      }
    },
    "corrective_actions": {
      "title": "Corrective Actions",
      "icon": "AssignmentTurnedInIcon",
      "type": "array",
      "fields": {
        "action_id": {
          "type": "string",
          "label": "ID"
        },
        "type": {
          "type": "select",
          "label": "Type",
          "options": ["Immediate", "Short-term", "Long-term", "System Change"]
        },
        "responsibility": {
          "type": "string",
          "label": "Responsibility"
        },
        "status": {
          "type": "select",
          "label": "Status",
          "options": ["Open", "In Progress", "Completed", "Overdue", "Verified"]
        },
        "recommendation": {
          "type": "text",
          "label": "Recommendation",
          "multiline": true
        }
      }
    },
    "investigation_team": {
      "title": "Investigation Team",
      "icon": "GroupIcon",
      "type": "array",
      "fields": {
        "name": {
          "type": "string",
          "label": "Name"
        },
        "id": {
          "type": "string",
          "label": "ID"
        },
        "department": {
          "type": "string",
          "label": "Department"
        },
        "role": {
          "type": "string",
          "label": "Role"
        }
      }
    },
    "approval": {
      "title": "Investigation Approval",
      "icon": "AssignmentTurnedInIcon",
      "fields": {
        "reviewed_by": {
          "type": "string",
          "label": "Reviewer Name"
        },
        "reviewer_id": {
          "type": "string",
          "label": "ID"
        },
        "designation": {
          "type": "string",
          "label": "Designation"
        },
        "date": {
          "type": "string",
          "label": "Approval Date"
        },
        "comments": {
          "type": "text",
          "label": "Comments",
          "multiline": true
        },
        "status": {
          "type": "select",
          "label": "Status",
          "options": ["pending", "approved", "rejected"]
        }
      }
    }
  }
}
